# Never ship machine-local artefacts generated by chrome-extension/native/install.sh.
# The wrapper embeds an absolute node path that only makes sense on the machine
# that ran install.sh; shipping it guarantees the next `npm i -g` overwrites a
# user's working wrapper with one hardcoded to the publisher's $HOME.
chrome-extension/native/host-wrapper.sh

# Test file — only used during development.
chrome-extension/native/host.test.cjs
